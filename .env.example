# Sceneify — environment variables
#
# Source of truth = Vercel Project Env. Pull locally with:
#   vercel env pull .env.local
#
# Never commit .env.local. Originals belong in 1Password (vault: "Sceneify").
# See .env.op.tpl for an `op run` template that injects from 1Password.

# --- LLM (prompt construction, image description) ----------------------------
OPENAI_API_KEY=

# --- fal.ai (image generation) -----------------------------------------------
FAL_KEY=

# --- NextAuth v5 -------------------------------------------------------------
# Generate AUTH_SECRET with:  openssl rand -base64 32
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# --- Vercel Blob (auto-injected by the Blob marketplace integration) --------
BLOB_READ_WRITE_TOKEN=

# --- Neon Postgres (auto-injected by the Neon marketplace integration) ------
DATABASE_URL=

# --- Internal API: Vercel OIDC verification ---------------------------------
# Caller projects mint these via VERCEL_OIDC_TOKEN; this app verifies them.
OIDC_TRUSTED_ISSUER=https://oidc.vercel.com/<team-slug>
OIDC_REQUIRED_AUDIENCE=
OIDC_ALLOWED_PROJECT_IDS=
OIDC_ALLOWED_ENVIRONMENTS=production,preview

# --- Optional ---------------------------------------------------------------
# Override Blob/local public base URL when storage runs outside Vercel.
# PUBLIC_BASE_URL=

# Used only by scripts/import-sources.ts for local imports.
# SCENEIFY_API_BASE=http://localhost:3000
